# Web environment variables. Copy to .env.local for local development.
#
# ---------- Local development ----------
# The frontend (:3000) and API (:4000) are same-site on localhost, so connect
# directly — the auth cookie works and no proxy is needed.
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
# API_PROXY_TARGET and NEXT_PUBLIC_SOCKET_URL are not needed locally.
#
# ---------- Production (set these in the Vercel project) ----------
# The frontend and API are on different domains, so the auth cookie would be a
# third-party cookie (blocked by Safari, deprecated in Chrome). To fix it, REST
# is proxied under the frontend's own /api/* path (first-party cookie), while
# the socket connects directly to the API over WebSocket using a short-lived
# token. That requires all three:
#
#   NEXT_PUBLIC_SERVER_URL=/api
#   API_PROXY_TARGET=https://<your-render-app>.onrender.com       # server-side: /api/* proxy target
#   NEXT_PUBLIC_SOCKET_URL=https://<your-render-app>.onrender.com # client-side: direct WebSocket target
#
# API_PROXY_TARGET and NEXT_PUBLIC_SOCKET_URL are the same Render URL (no
# trailing slash).
