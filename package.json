{
  "name": "realtime-canvas",
  "private": true,
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"npm run dev -w web\" \"npm run dev -w server\"",
    "build": "npm run build -w web",
    "dev:web": "npm run dev -w web",
    "dev:server": "npm run dev -w server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
